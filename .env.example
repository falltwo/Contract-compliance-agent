PINECONE_API_KEY=
PINECONE_INDEX=agent-demo

# Gemini（LLM）
GOOGLE_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Embedding 設定
# EMBEDDING_PROVIDER 可選：gemini（預設）、bge-m3
EMBEDDING_PROVIDER=gemini
GEMINI_EMBED_MODEL=gemini-embedding-001

# 網路搜尋（Tavily）

TAVILY_API_KEY=

# Firecrawl（網頁擷取 / 搜尋 / 爬站）
# 取得 API key: https://firecrawl.dev
FIRECRAWL_API_KEY=


# 可選：用 output_dimensionality 降維，需與 Pinecone index 維度一致
# （如果不填，程式會自動讀取 index 維度來對齊）
# EMBED_DIM=1024

# 資料夾與檢索參數
RAG_DATA_DIR=data
TOP_K=5


#圖表
USE_ECHARTS_MCP=1




#uv run python eval/run_eval.py --groq
#Eval 運行記錄
EVAL_LOG_ENABLED=1
#Eval 運行記錄路徑
EVAL_LOG_PATH=eval_runs.jsonl


GROQ_API_KEY=